{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "noEmit": true,
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@arrtemplar/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": [
    "test/**/*.ts",
    "scripts/**/*.ts",
    "apps/server/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "packages/*/src/**/*.ts"
  ]
}