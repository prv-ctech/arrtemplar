SERVER_PORT=3000
WEB_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:3000
# `VITE_*` variables are exposed to the browser bundle. Never put secrets in them.
VITE_API_BASE_URL=
DATABASE_URL=data/db/arrtemplar-dev.sqlite
# Local HTTP development only. Use `true` behind HTTPS in deployed environments.
SESSION_COOKIE_SECURE=false
LOG_LEVEL=debug
LOG_FILE_PATH=data/logs/arrtemplar.jsonl
LOG_FILE_MAX_SIZE_BYTES=10485760
LOG_FILE_MAX_FILES=5
LOG_CONSOLE=true
