{
  "name": "@arrweeb-anime/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cd ../.. && DATABASE_URL=data/db/arrweeb-test.sqlite bun test test/apps/server",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun src/db/migrate.ts"
  },
  "dependencies": {
    "@arrweeb-anime/shared": "workspace:*",
    "@elysia/cors": "latest",
    "@elysia/openapi": "latest",
    "@logtape/drizzle-orm": "^2.1.0",
    "@logtape/elysia": "^2.1.0",
    "@logtape/file": "^2.1.0",
    "@logtape/logtape": "^2.1.0",
    "@logtape/redaction": "^2.1.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "elysiajs-helmet": "1.0.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "latest"
  },
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  }
}
