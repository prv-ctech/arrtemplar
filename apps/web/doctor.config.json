{
  "rootDir": ".",
  "lint": true,
  "deadCode": false,
  "warnings": true,
  "blocking": "error",
  "noScore": true,
  "share": false,
  "adoptExistingLintConfig": true,
  "ignore": {
    "files": [
      "dist/**",
      "coverage/**",
      "storybook-static/**",
      "src/**/*.test.ts",
      "src/**/*.test.tsx",
      "src/**/*.spec.ts",
      "src/**/*.spec.tsx",
      "src/**/__tests__/**",
      "src/**/__mocks__/**",
      "src/**/__fixtures__/**"
    ]
  }
}
