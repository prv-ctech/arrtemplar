{
  "name": "@arrtemplar/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite --no-open",
    "build": "tsc -p tsconfig.json --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cd ../.. && bun test test/apps/web",
    "doctor": "CI=true react-doctor . --diff false --no-score --blocking error"
  },
  "dependencies": {
    "@arrtemplar/server": "workspace:*",
    "@arrtemplar/shared": "workspace:*",
    "@elysia/eden": "^1.4.10",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ogl": "^1.0.11",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
