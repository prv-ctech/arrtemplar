{
  "name": "arrtemplar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:typecheck": "tsc -b --noEmit --watch --preserveWatchOutput",
    "assets:profile-media": "bun scripts/generate-profile-media.ts",
    "build": "bun run --cwd packages/shared build && bun run --cwd apps/server build && bun run --cwd apps/web build",
    "typecheck": "bun run --cwd packages/shared typecheck && bun run --cwd apps/server typecheck && bun run --cwd apps/web typecheck && tsc -p tsconfig.test.json --noEmit",
    "test": "DATABASE_URL=data/db/arrtemplar-test.sqlite bun test test",
    "check": "bun run check:quality:code",
    "check:code:fallow": "fallow audit --quiet",
    "check:code:fallow:full": "fallow --summary",
    "check:code:fallow:fix:dry-run": "fallow fix --dry-run",
    "check:code:react-doctor": "CI=true react-doctor apps/web --scope changed --no-score --blocking error",
    "check:code:react-doctor:full": "CI=true react-doctor apps/web --scope full --no-score --blocking error",
    "check:code:typecheck": "bun run typecheck",
    "check:code:test": "DATABASE_URL=data/db/arrtemplar-test.sqlite bun test test",
    "check:code:biome": "biome check .",
    "check:quality:code": "bun run check:code:fallow && bun run check:code:react-doctor && bun run check:code:typecheck && bun run check:code:test && bun run check:code:biome",
    "check:quality:code:full": "bun run check:code:fallow:full && bun run check:code:react-doctor:full && bun run check:code:typecheck && bun run check:code:test && bun run check:code:biome",
    "format": "biome check --write .",
    "write:quality:code": "fallow fix && biome check --write .",
    "db:generate": "bun run --cwd apps/server db:generate",
    "db:migrate": "bun run --cwd apps/server db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@logtape/logtape": "^2.2.0",
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "fallow": "2.101.0",
    "react-doctor": "^0.5.8",
    "typescript": "^6.0.3"
  },
  "module": "index.ts",
  "overrides": {
    "esbuild": "0.28.0"
  },
  "patchedDependencies": {
    "elysiajs-helmet@1.0.5": "patches/elysiajs-helmet@1.0.5.patch"
  }
}
