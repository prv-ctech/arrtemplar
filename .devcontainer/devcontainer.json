{
  "name": "Arrtemplar",
  "image": "oven/bun:debian",
  "init": true,
  "containerUser": "root",
  "remoteUser": "root",
  "updateRemoteUserUID": false,
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "root",
      "installZsh": true,
      "installOhMyZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "os-provided",
      "installTools": false
    },
    "ghcr.io/devcontainers-extra/features/uv:1": {},
    "ghcr.io/devcontainers-extra/features/ruff:2": {}
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/root/.local/bin"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "SmallMain.vscode-unify-chat-provider",
        "Catppuccin.catppuccin-vsc",
        "thang-nm.flow-icons",
        "tonybaloney.vscode-pets",
        "vscjava.vscode-java-debug",
        "github.vscode-github-actions",
        "vscjava.vscode-java-pack",
        "bierner.markdown-mermaid",
        "DavidAnson.vscode-markdownlint"
      ],
      "settings": {
        "workbench.browser.openLocalhostLinks": true,
        "workbench.browser.enableChatTools": true,
        "python.analysis.typeCheckingMode": "basic",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "ruff.nativeServer": "on"
      }
    }
  },

  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": {
      "label": "Bun API",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite web app",
      "onAutoForward": "silent",
      "protocol": "http"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "notify"
  },

  "postCreateCommand": "bun --version && python3 --version && uv --version && ruff --version && if [ -f bun.lock ] || [ -f bun.lockb ]; then bun install --frozen-lockfile; elif [ -f package.json ]; then bun install; fi",
  "waitFor": "postCreateCommand"
}